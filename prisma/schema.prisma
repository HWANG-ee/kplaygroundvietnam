generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // "user" | "admin"
  mileage   Int      @default(0)
  createdAt DateTime @default(now())

  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist[]
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  kind     String    @default("album") // "album" | "goods"
  order    Int       @default(0)
  products Product[]
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  artist       String
  description  String   @default("")
  image        String
  images       String   @default("[]") // JSON array of extra images
  price        Int      // 정가 (consumer price)
  salePrice    Int      // 판매가
  stock        Int      @default(100)
  versions     String   @default("[]") // JSON array of version names
  badge        String   @default("") // "예약" | "신상" | "베스트" | "핫딜" | "재입고" | ""
  isPreorder   Boolean  @default(false)
  isBest       Boolean  @default(false)
  isNew        Boolean  @default(false)
  isHotDeal    Boolean  @default(false)
  isRestocked  Boolean  @default(false)
  releaseDate  DateTime?
  createdAt    DateTime @default(now())

  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  orderItems   OrderItem[]
  reviews      Review[]
  wishlist     Wishlist[]
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  status      String   @default("결제완료") // 결제완료 | 배송중 | 배송완료 | 취소
  total       Int
  recipient   String
  phone       String
  address     String
  memo        String   @default("")
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Int
  version   String  @default("")

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  content   String
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model SiteSetting {
  id              String   @id @default("site") // 단일 행(싱글톤)
  companyName     String   @default("(주)케이플레이그라운드")
  ceo             String   @default("홍길동")
  bizNumber       String   @default("000-00-00000")
  mailOrderNumber String   @default("2026-서울강남-00000")
  address         String   @default("서울특별시 강남구 케이팝로 42, 3층")
  privacyOfficer  String   @default("김덕질")
  phone           String   @default("1670-0000")
  hours           String   @default("평일 10:00 - 18:00\n점심 12:30 - 13:30\n주말/공휴일 휴무")
  instagram       String   @default("#")
  youtube         String   @default("#")
  twitter         String   @default("#")
  updatedAt       DateTime @updatedAt
}
